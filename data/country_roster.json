{
  "metadata": {
    "version": "1.0",
    "last_updated": "2026-06-04",
    "author": "Sana Asif Ahmad",
    "description": "Comprehensive roster of Global South countries in scope for the tracker, with the verifiable inclusion logic. Distinguishes fully-profiled countries (in countries.json) from roster-only candidates awaiting full profiling."
  },
  "selection_criteria": {
    "rule": "A country is IN SCOPE if it meets ALL THREE criteria below.",
    "criteria": [
      {
        "id": "income",
        "test": "World Bank income group is low, lower-middle, or upper-middle (i.e., NOT high-income).",
        "verifiable_source": "World Bank country & lending groups (updated each July)."
      },
      {
        "id": "region",
        "test": "Located in a Global South region: Sub-Saharan Africa, North Africa & MENA, South Asia, Southeast Asia, Central Asia, Latin America & Caribbean, or Pacific Islands.",
        "verifiable_source": "UN M49 standard regional classification."
      },
      {
        "id": "governance_to_track",
        "test": "Has a national AI strategy that is published, officially drafted, or in formal development — OR has formally endorsed a regional AI framework (AU Continental AI Strategy / ASEAN Guide on AI Governance).",
        "verifiable_source": "OECD.AI Policy Observatory (oecd.ai/dashboards/national)."
      }
    ],
    "note_on_proxies": "'G77 membership' was rejected as a proxy because it excludes Mexico (not a G77 member) yet Mexico is clearly in scope. Income + UN region is cleaner and reproducible.",
    "profiling_priority": "Among in-scope countries, full profiling is prioritised by (1) regional coverage — at least one per region, (2) population weight, and (3) availability of primary-source data (UN DCO country offices). This is why the first 8 span South Asia, Southeast Asia, Sub-Saharan Africa, and Latin America."
  },
  "regions_covered": [
    "Central Asia",
    "Latin America & Caribbean",
    "North Africa & MENA",
    "Pacific Islands",
    "South Asia",
    "Southeast Asia",
    "Sub-Saharan Africa"
  ],
